# ---- Base image (Node + Debian) ----
FROM node:22-bookworm

# ---- Install Python ----
RUN apt-get update \
  && apt-get install -y --no-install-recommends python3 python3-pip python3-venv \
  && rm -rf /var/lib/apt/lists/*

WORKDIR /app

# ---- Install Node deps first (better caching) ----
COPY package*.json ./
RUN npm ci --omit=dev

# ---- Copy the rest of the project ----
COPY . .

# ---- Install Python deps ----
# Adjust this path if your requirements.txt is elsewhere
RUN python3 -m pip install --no-cache-dir -r ai-models/price-prediction/requirements.txt

# ---- Expose your server port ----
# Change if your app runs on a different port
EXPOSE 3000

# ---- Start Node server ----
CMD ["npm", "start"]
